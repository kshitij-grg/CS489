{
  "info": {
    "_postman_id": "ae522a00-5605-4fc9-a1f7-410bc11829c5",
    "name": "ADS Dental Surgery Web API",
    "description": "Lab 9 - JWT secured RESTful Web API for ADS Dental Surgery Appointment Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "14292653"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "0. Authenticate (Get JWT)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "let token = pm.response.text().trim();",
              "if (token.startsWith('\\\"') && token.endsWith('\\\"')) {",
              "  token = token.slice(1, -1);",
              "}",
              "pm.collectionVariables.set('jwt_token', token);",
              "",
              "pm.test(\"JWT token captured\", function () {",
              "  pm.expect(token).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/adsweb/api/v1/service/public/authenticate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "adsweb",
            "api",
            "v1",
            "service",
            "public",
            "authenticate"
          ]
        },
        "description": "Authenticate and store JWT in collection variable jwt_token"
      },
      "response": []
    },
